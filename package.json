{
  "name": "wechat-platform",
  "version": "1.2.8",
  "type": "module",
  "scripts": {
    "dev": "vite --mode development --host",
    "test": "vite --mode test --host",
    "mock": "vite --mode mock --host",
    "build": "vite build && node build-log.js",
    "build:ts": "vue-tsc --noEmit && vite build",
    "staging": "vite --mode staging",
    "serve": "vite preview",
    "lint": "eslint --ext .vue,.js,.ts,.jsx,.tsx src",
    "lint:fix": "eslint --ext .vue,.js,.ts,.jsx,.tsx,.cjs --ignore-path .eslintignore . --fix",
    "release": "release-it",
    "changelog": "conventional-changelog -p chestnut -i CHANGELOG.md -s -r 0",
    "prepare": "npx husky install"
  },
